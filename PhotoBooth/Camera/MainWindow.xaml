<Window
    x:Class="SaftApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:SaftApp"
    x:Name="Root"
    mc:Ignorable="d"
    WindowStyle="None"
    ResizeMode="NoResize"
    WindowState="Maximized"
    Background="Black"
    ShowInTaskbar="True"
    Topmost="False"
    Title="Photobooth Companion"
    Loaded="Window_Loaded">

    <Window.Resources>
        <!-- Keep these for XAML storyboards, values will also be set from code on startup -->
        <Duration x:Key="FlashInDuration">0:0:1</Duration>
        <Duration x:Key="FlashOutDuration">0:0:2</Duration>
        <Duration x:Key="HoldDuration">0:0:0.3</Duration>
        <Duration x:Key="PreviewDuration">0:0:10</Duration>

        <Storyboard x:Key="CountdownNumberInOut">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="tbOverlayScale"
                                           Storyboard.TargetProperty="ScaleX"
                                           Duration="0:0:1">
                <EasingDoubleKeyFrame KeyTime="0%" Value="0.6">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="35%" Value="1.0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="65%" Value="1.0"/>
                <EasingDoubleKeyFrame KeyTime="100%" Value="1.0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseIn"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>

            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="tbOverlayScale"
                                           Storyboard.TargetProperty="ScaleY"
                                           Duration="0:0:1">
                <EasingDoubleKeyFrame KeyTime="0%" Value="0.6">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="35%" Value="1.0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="65%" Value="1.0"/>
                <EasingDoubleKeyFrame KeyTime="100%" Value="1.0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseIn"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>

            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="tbOverlayTrans"
                                           Storyboard.TargetProperty="Y"
                                           Duration="0:0:1">
                <EasingDoubleKeyFrame KeyTime="0%" Value="-400">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="35%" Value="0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="65%" Value="0"/>
                <EasingDoubleKeyFrame KeyTime="100%" Value="120">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseIn"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>

            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="tbOverlay"
                                           Storyboard.TargetProperty="Opacity"
                                           Duration="0:0:1">
                <DiscreteDoubleKeyFrame KeyTime="0%" Value="0"/>
                <DiscreteDoubleKeyFrame KeyTime="5%" Value="1"/>
                <DiscreteDoubleKeyFrame KeyTime="65%" Value="1"/>
                <DiscreteDoubleKeyFrame KeyTime="100%" Value="0"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <Storyboard x:Key="FlashInFast">
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="flashOverlay"
                                           Storyboard.TargetProperty="Visibility"
                                           Duration="{StaticResource FlashInDuration}">
                <DiscreteObjectKeyFrame KeyTime="0%" Value="{x:Static Visibility.Visible}"/>
            </ObjectAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="flashOverlay"
                                           Storyboard.TargetProperty="Opacity"
                                           Duration="{StaticResource FlashInDuration}"
                                           FillBehavior="Stop">
                <EasingDoubleKeyFrame KeyTime="0%" Value="0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="100%" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <Storyboard x:Key="FlashOutSmooth">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="flashOverlay"
                                           Storyboard.TargetProperty="Opacity"
                                           Duration="{StaticResource FlashOutDuration}">
                <EasingDoubleKeyFrame KeyTime="0%" Value="1">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseIn"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="100%" Value="0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <CubicEase EasingMode="EaseIn"/>
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="flashOverlay"
                                           Storyboard.TargetProperty="Visibility"
                                           Duration="{StaticResource FlashOutDuration}">
                <DiscreteObjectKeyFrame KeyTime="100%" Value="{x:Static Visibility.Collapsed}"/>
            </ObjectAnimationUsingKeyFrames>
        </Storyboard>
    </Window.Resources>

    <Grid SnapsToDevicePixels="True">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="25"/>
            <ColumnDefinition/>
            <ColumnDefinition Width="25"/>
        </Grid.ColumnDefinitions>

        <!-- Left: capture button -->
        <Button Grid.Column="0"
                x:Name="bCapture"
                Background="DarkRed"
                Height="300"
                Width="25"
                Click="bCapture_Click"/>

        <Grid Grid.Column="1" ClipToBounds="True">
            <Image x:Name="PreviewControl"
                   Stretch="Uniform"
                   IsHitTestVisible="False"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <!-- Video playback element -->
            <MediaElement x:Name="videoControl"
                          LoadedBehavior="Manual"
                          UnloadedBehavior="Stop"
                          Visibility="Collapsed"
                          Stretch="Uniform"
                          IsHitTestVisible="False"
                          MediaEnded="videoControl_MediaEnded"/>

            <Image x:Name="imageControl"
                   Stretch="Uniform"
                   Visibility="Collapsed"
                   IsHitTestVisible="False"
                   RenderOptions.BitmapScalingMode="HighQuality"/>

            <TextBlock x:Name="tbOverlay"
                       Grid.ZIndex="2"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="350"
                       FontFamily="Verdana"
                       FontWeight="Bold"
                       Foreground="DarkRed"
                       Opacity="0"
                       TextAlignment="Center"
                       RenderTransformOrigin="0.5,0.5"
                       CacheMode="BitmapCache">
                <TextBlock.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="tbOverlayScale" ScaleX="1" ScaleY="1"/>
                        <TranslateTransform x:Name="tbOverlayTrans" X="0" Y="0"/>
                    </TransformGroup>
                </TextBlock.RenderTransform>
            </TextBlock>

            <Rectangle x:Name="flashOverlay"
                       Grid.ZIndex="3"
                       Fill="White"
                       Opacity="0"
                       Visibility="Collapsed"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch"/>
        </Grid>

        <!-- Right: video button -->
        <Button Grid.Column="2"
                x:Name="bVideo"
                Background="DarkRed"
                Height="300"
                Width="25"
                Click="bVideo_Click"/>
    </Grid>
</Window>
